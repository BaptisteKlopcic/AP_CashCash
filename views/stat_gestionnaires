<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistiques</title>
    <style>
        body { font-family: Arial; margin:20px; }
        select { padding:10px; border-radius:5px; border:1px solid #ccc; }
        .stats { margin-top:20px; padding:15px; background:white; border-radius:8px; box-shadow:0 0 5px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <h2>Statistiques mensuelles</h2>

    <label>Mois :</label>
    <select>
        <option>Janvier</option>
        <option>Février</option>
    </select>

    <label>Technicien :</label>
    <select>
        <option>Martin</option>
        <option>Durand</option>
    </select>

    <div class="stats">
        <p><strong>Interventions réalisées :</strong> 12</p>
        <p><strong>Kilomètres parcourus :</strong> 145 km</p>
        <p><strong>Durée totale :</strong> 8h 30</p>
    </div>
</body>
</html>
